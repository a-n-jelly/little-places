# Supabase - get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # used by scripts/import-to-supabase.js (needs UPDATE permission)

# Anthropic - get this from console.anthropic.com > API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...       # used by scripts/ (server-side)

# Google Places API - get from console.cloud.google.com > APIs & Services
# Enable "Places API" and create an API key restricted to Places API
GOOGLE_PLACES_API_KEY=AIza...      # used by scripts/fetch-google-places.js

# Mapbox - get from mapbox.com > Account > Access Tokens
VITE_MAPBOX_TOKEN=pk.eyJ1...
